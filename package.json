{
  "name": "gods-assistant",
  "version": "0.1.0",
  "description": "Voice-controlled desktop AI assistant",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:electron\" \"npm run dev:engine\"",
    "dev:electron": "vite",
    "dev:engine": "cd engine && python main.py",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "package": "npm run build && electron-builder",
    "install:engine": "bash scripts/install-engine.sh"
  },
  "dependencies": {
    "framer-motion": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
